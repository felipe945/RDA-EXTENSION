{
  "manifest_version": 3,
  "name": "FanBasis Sales 2.0",
  "version": "2.0.0",
  "description": "Unified sales pipeline — Instagram, LinkedIn, Twitter, Gmail in one place",

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "sidePanel",
    "tabs",
    "clipboardWrite",
    "identity"
  ],

  "host_permissions": [
    "https://www.instagram.com/*",
    "https://i.instagram.com/*",
    "https://www.linkedin.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://*.manychat.com/*",
    "https://*.agorapulse.com/*",
    "https://unified-sales-ops.vercel.app/*",
    "http://localhost:3000/*",
    "https://www.googleapis.com/*"
  ],

  "oauth2": {
    "client_id": "257819947065-ij83mq0iav5ovap9ma0p0us1hr2qbt5s.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.readonly",
      "https://www.googleapis.com/auth/calendar.events"
    ]
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["scripts-data.js", "instagram.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["twitter.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.manychat.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.agorapulse.com/*"],
      "js": ["agora.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["page-interceptor.js", "dashboard.html"],
      "matches": ["https://www.instagram.com/*", "<all_urls>"]
    }
  ],

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_title": "FanBasis Sales 2.0",
    "default_popup": "popup.html",
    "default_icon": { "48": "icon48.png", "128": "icon128.png" }
  },

  "icons": { "48": "icon48.png", "128": "icon128.png" }
}
