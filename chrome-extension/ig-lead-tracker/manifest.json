{
  "manifest_version": 3,
  "name": "FanMas",
  "version": "2.8.2",
  "description": "Unified sales pipeline — Instagram, LinkedIn, Twitter, Gmail in one place",
  "key": "",

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "sidePanel",
    "tabs",
    "clipboardWrite",
    "identity"
  ],

  "host_permissions": [
    "https://www.instagram.com/*",
    "https://i.instagram.com/*",
    "https://www.linkedin.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://*.manychat.com/*",
    "https://*.agorapulse.com/*",
    "https://fanmas.vercel.app/*",
    "https://unified-sales-ops.vercel.app/*",
    "http://localhost:3000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["scripts-data.js", "outreach-queue.js", "instagram.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["twitter.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.manychat.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.agorapulse.com/*"],
      "js": ["agora.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["page-interceptor.js", "dashboard.html"],
      "matches": ["https://www.instagram.com/*", "<all_urls>"]
    }
  ],

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_title": "FanMas",
    "default_popup": "popup.html",
    "default_icon": { "16": "icon16.png", "32": "icon32.png", "48": "icon48.png", "128": "icon128.png" }
  },

  "icons": { "16": "icon16.png", "32": "icon32.png", "48": "icon48.png", "128": "icon128.png" }
}
